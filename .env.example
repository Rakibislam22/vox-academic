# Example environment variables for vox-academic
# Copy this file to .env.local and fill in real values for local development.

# MongoDB connection (used by src/lib/mongodb.ts)
MONGO_URI="mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/<dbname>?retryWrites=true&w=majority"
# alternative name some setups use
MONGO_URL=""

# NextAuth / authentication
# Either set AUTH_SECRET or NEXTAUTH_SECRET. Use a long random string (32+ chars).
AUTH_SECRET="replace-with-a-secure-random-string"
NEXTAUTH_SECRET=""
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Groq API (free-tier / fast PDF summarization)
GROQ_API_KEY=""
# Optional override if you want to change the model later
GROQ_MODEL="llama-3.3-70b-versatile"

# Hugging Face API (free-tier TTS generation)
HUGGINGFACE_API_TOKEN=""
# Default: facebook/mms-tts-eng. Override this with a different HF model if needed.
HUGGINGFACE_TTS_MODEL="facebook/mms-tts-eng"
# Optional direct endpoint override for a community space or custom inference URL.
HUGGINGFACE_TTS_ENDPOINT=""

# Vercel deployment (optional, used by CI/deploy scripts)
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
